<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Playfair+Display:wght@500&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f5f5f0;
      font-family: 'DM Sans', sans-serif;
    }

    .card {
      width: 100%;
      max-width: 400px;
      background: #fff;
      border-radius: 16px;
      padding: 2rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }

    .brand {
      text-align: center;
      margin-bottom: 1.5rem;
    }

    .brand h1 {
      font-size: 22px;
      color: #1a1a2e;
    }

    .field {
      margin-bottom: 1rem;
    }

    .field label {
      font-size: 12px;
      color: #666;
      display: block;
      margin-bottom: 5px;
    }

    .input-wrap {
      position: relative;
    }

    .field input {
      width: 100%;
      height: 40px;
        padding: 0 15px;
      border-radius: 8px;
      border: 1px solid #ddd;
      outline: none;
    }

    .toggle-pw {
      position: absolute;
      right: 8px;
      top: 50%;
      transform: translateY(-50%);
      border: none;
      background: none;
      cursor: pointer;
    }

    .btn-login {
      width: 100%;
      height: 40px;
      background: #1a1a2e;
      color: #fff;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      margin-top: 10px;
    }

    .btn-login:hover {
      opacity: 0.9;
    }

    .signup {
      text-align: center;
      margin-top: 1rem;
      font-size: 13px;
    }

    .signup a {
      color: #3b82f6;
      text-decoration: none;
    }

    h4{
      text-align: center;
      color: red;
    }
  </style>
</head>
<body>

  <div class="card">
    <div class="brand">
      <h1>Welcome back</h1>
      <p>Login in to your account</p>
    </div>
    <h4><%= error %></h4>
    <!-- ✅ FORM START -->
    <form action="/login" method="post">
      <div class="field">
        <label>Username</label>
        <div class="input-wrap">
          <input type="text" name="username" placeholder="Enter username" required>
        </div>
      </div>

      <div class="field">
        <label>Password</label>
        <div class="input-wrap">
          <input type="password" id="password" name="password" placeholder="Enter password" required>

          <!-- ✅ FIX: type="button" -->
          <button type="button" class="toggle-pw" onclick="togglePassword()">👁</button>
        </div>
      </div>

      <!-- ✅ BUTTON INSIDE FORM -->
      <button class="btn-login" type="submit">Login </button>

    </form>

    <!-- ✅ FORM END -->

    <p class="signup">
           Don't have an account <a href="/signform">Sign up</a>
    </p>

  </div>

  <!-- ✅ PASSWORD TOGGLE SCRIPT -->
  <script>
    function togglePassword() {
      const pw = document.getElementById("password");
      if (pw.type === "password") {
        pw.type = "text";
      } else {
        pw.type = "password";
      }
    }
  </script>

</body>
</html>